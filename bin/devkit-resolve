#!/usr/bin/env bash
# devkit-resolve: resolve enabled plugins and optionally run an adapter.
#
# Usage:
#   devkit-resolve                     # List resolved plugin names
#   devkit-resolve --init              # Create .devkit/toolkit.json interactively
#   devkit-resolve --dirs              # List resolved plugin directories
#   devkit-resolve --validate          # Validate config only
#   devkit-resolve --adapter=claude    # Resolve + generate Claude Code config
#   devkit-resolve --adapter=cursor    # Resolve + generate Cursor config
#   devkit-resolve --adapter=codex     # Resolve + generate Codex config
#
# Environment:
#   DEVKIT_PROJECT_ROOT  Override project root (default: CWD)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TOOLKIT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../adapters/_lib/resolve.sh
source "$TOOLKIT_ROOT/adapters/_lib/resolve.sh"

usage() {
  cat <<'EOF'
devkit-resolve — resolve devkit-toolkit plugins for a project

Usage:
  devkit-resolve                     List resolved plugin names (one per line)
  devkit-resolve --init              Create .devkit/toolkit.json interactively
  devkit-resolve --dirs              List resolved plugin directories
  devkit-resolve --validate          Validate .devkit/toolkit.json only
  devkit-resolve --adapter=<name>    Resolve + generate config for an adapter
                                   Supported: claude, cursor, codex

Options:
  -h, --help      Show this help
  --project=DIR   Override project root (default: CWD)

Environment:
  DEVKIT_PROJECT_ROOT   Same as --project
EOF
  exit 0
}

MODE="list"
ADAPTER=""

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      usage
      ;;
    --init)
      MODE="init"
      ;;
    --validate)
      MODE="validate"
      ;;
    --dirs)
      MODE="dirs"
      ;;
    --adapter=*)
      MODE="adapter"
      ADAPTER="${arg#--adapter=}"
      ;;
    --project=*)
      export DEVKIT_PROJECT_ROOT="${arg#--project=}"
      ;;
    *)
      echo "Unknown option: $arg" >&2
      usage
      ;;
  esac
done

_init_toolkit() {
  local config_dir="$PROJECT_ROOT/.devkit"
  local config_file="$config_dir/toolkit.json"

  if [ -f "$config_file" ]; then
    echo "ERROR: $config_file already exists." >&2
    exit 1
  fi

  local relpath
  relpath=$(toolkit_relpath)
  local schema_ref="$relpath/schemas/toolkit.schema.json"

  local examples_dir="$TOOLKIT_ROOT/examples"
  local -a preset_files=()
  local -a preset_labels=()

  for f in "$examples_dir"/*.json; do
    [ -f "$f" ] || continue
    local base
    base=$(basename "$f" .json)
    local desc
    desc=$(jq -r '.enabled | join(", ")' "$f")
    preset_files+=("$f")
    preset_labels+=("$base  ($desc)")
  done

  echo ""
  echo "Available presets:"
  local i=1
  for label in "${preset_labels[@]}"; do
    echo "  $i) $label"
    ((i++))
  done
  echo "  $i) custom — pick plugins manually"
  echo ""

  local total=${#preset_files[@]}
  local choice
  read -rp "Select preset [1-$((total + 1))]: " choice

  local enabled_json

  if [ "$choice" -ge 1 ] 2>/dev/null && [ "$choice" -le "$total" ] 2>/dev/null; then
    enabled_json=$(jq '.enabled' "${preset_files[$((choice - 1))]}")
  elif [ "$choice" -eq $((total + 1)) ] 2>/dev/null; then
    local -a all_plugins=()
    for manifest in "$TOOLKIT_ROOT"/plugins/*/plugin.json; do
      [ -f "$manifest" ] || continue
      local pname pdesc player pdefault
      pname=$(jq -r '.name' "$manifest")
      pdesc=$(jq -r '.description' "$manifest")
      player=$(jq -r '.layer' "$manifest")
      pdefault=$(jq -r '.defaultEnabled // false' "$manifest")
      [ "$pdefault" = "true" ] && continue
      all_plugins+=("$pname|$pdesc|$player")
    done

    echo ""
    echo "Available plugins (devkit-core is always included):"
    i=1
    for entry in "${all_plugins[@]}"; do
      local pname pdesc player
      pname=$(echo "$entry" | cut -d'|' -f1)
      pdesc=$(echo "$entry" | cut -d'|' -f2)
      player=$(echo "$entry" | cut -d'|' -f3)
      echo "  $i) $pname [$player] — $pdesc"
      ((i++))
    done
    echo ""

    local selections
    read -rp "Enter plugin numbers separated by spaces: " selections

    enabled_json="[]"
    for sel in $selections; do
      if [ "$sel" -ge 1 ] 2>/dev/null && [ "$sel" -le ${#all_plugins[@]} ] 2>/dev/null; then
        local selected_name
        selected_name=$(echo "${all_plugins[$((sel - 1))]}" | cut -d'|' -f1)
        enabled_json=$(echo "$enabled_json" | jq --arg n "$selected_name" '. + [$n]')
      fi
    done
  else
    echo "Invalid selection." >&2
    exit 1
  fi

  mkdir -p "$config_dir"
  jq -n \
    --arg schema "$schema_ref" \
    --argjson enabled "$enabled_json" \
    '{"$schema": $schema, version: 1, enabled: $enabled}' > "$config_file"

  echo ""
  echo "Created: .devkit/toolkit.json"
  echo ""

  local resolved
  resolved=$(resolve_plugins)
  echo "Resolved plugins:"
  echo "$resolved" | while read -r name; do echo "  - $name"; done

  local relpath
  relpath=$(toolkit_relpath)
  echo ""
  echo "Next step: generate config for your IDE/tool:"
  echo ""
  echo "  $relpath/bin/devkit-resolve --adapter=claude"
  echo "  $relpath/bin/devkit-resolve --adapter=cursor"
  echo "  $relpath/bin/devkit-resolve --adapter=codex"
}

case "$MODE" in
  init)
    _init_toolkit
    ;;
  validate)
    resolved=$(resolve_plugins)
    count=$(echo "$resolved" | wc -l | tr -d ' ')
    echo "OK: $count plugins resolved"
    echo "$resolved" | while read -r name; do echo "  - $name"; done
    ;;
  dirs)
    resolve_plugin_dirs
    ;;
  list)
    resolve_plugins
    ;;
  adapter)
    adapter_script="$TOOLKIT_ROOT/adapters/$ADAPTER/generate"
    if [[ ! -f "$adapter_script" ]]; then
      echo "ERROR: Unknown adapter '$ADAPTER'. Available:" >&2
      for d in "$TOOLKIT_ROOT"/adapters/*/generate; do
        [[ -f "$d" ]] && echo "  - $(basename "$(dirname "$d")")" >&2
      done
      exit 1
    fi
    exec bash "$adapter_script"
    ;;
esac
